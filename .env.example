# ================================================================
# Neobank Backend - Environment Configuration Template
# ================================================================
# Copy this file to .env and update with your actual values
# for local/dev environments. For production, use secure secret
# management (K8s secrets, Vault, etc.)
#
# NEVER commit .env with real secrets to version control.
# ================================================================

# ================================================================
# Spring Configuration
# ================================================================

# Active Spring profile: dev, test, or prod
SPRING_PROFILES_ACTIVE=dev

# ================================================================
# Database Configuration
# ================================================================

# PostgreSQL connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neobank
DB_USER=neobank
DB_PASSWORD=neobank_dev_password_change_in_production

# ================================================================
# Redis Configuration
# ================================================================

# Redis connection details
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================================================
# Kafka Configuration
# ================================================================

# Kafka bootstrap servers (comma-separated)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Enable/disable Kafka publishing
KAFKA_ENABLED=false
KAFKA_PUBLISH=false

# Kafka topic names
KAFKA_TOPIC_TRANSFER_COMPLETED=neobank.transfer.completed
KAFKA_TOPIC_TRANSFER_REJECTED=neobank.transfer.rejected
KAFKA_TOPIC_TRANSFER_REVERSED=neobank.transfer.reversed
KAFKA_TOPIC_ACCOUNT_CREATED=neobank.account.created
KAFKA_TOPIC_USER_REGISTERED=neobank.user.registered

# ================================================================
# JWT Security Configuration
# ================================================================

# CRITICAL: Must be set to a strong random value (minimum 64 chars)
# Generate with: openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=your-secret-key-minimum-64-characters-long-change-this-in-production-00000000

# CRITICAL: Must be set to a strong random value (minimum 64 chars)
# Generate with: openssl rand -base64 48 | tr -d '\n'
JWT_REFRESH_TOKEN_PEPPER=your-refresh-pepper-minimum-64-characters-long-change-in-production-000000

# JWT token validity times (in seconds)
JWT_ISSUER=neobank
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ================================================================
# Risk Management Configuration
# ================================================================

# Maximum single transfer amount
RISK_MAX_TRANSFER=10000.00

# Daily outgoing transfer limit
RISK_DAILY_LIMIT=20000.00

# Velocity check window (minutes)
RISK_VELOCITY_WINDOW=10

# Maximum transfers in velocity window
RISK_VELOCITY_MAX=5

# New account age threshold (hours)
RISK_NEW_ACCOUNT_AGE=24

# New account high-value transfer threshold
RISK_HIGH_VALUE_THRESHOLD=2500.00

# ================================================================
# Rate Limiting Configuration
# ================================================================

# Enable/disable rate limiting
RATELIMIT_ENABLED=true

# ================================================================
# Outbox Pattern Configuration
# ================================================================

# Enable/disable outbox event processing
OUTBOX_ENABLED=true

# Outbox processor settings (milliseconds)
OUTBOX_PROCESSOR_INTERVAL=5000
OUTBOX_PROCESSOR_INITIAL_DELAY=1000
OUTBOX_PROCESSOR_BATCH_SIZE=100
OUTBOX_PROCESSOR_MAX_ATTEMPTS=3
OUTBOX_PROCESSOR_TIMEOUT=300000

# ================================================================
# Server Configuration
# ================================================================

# Application port
SERVER_PORT=8080

# ================================================================
# Prometheus Configuration
# ================================================================

# Enable unauthenticated /actuator/prometheus endpoint (recommended only in trusted networks)
PROMETHEUS_PUBLIC_ENDPOINT_ENABLED=false

# ================================================================
# Backup Operation Defaults (used by ops scripts)
# ================================================================

# Local folder where database backups are generated
BACKUP_DIR=./ops/backups

# Compression level for pg_dump output (0-9)
BACKUP_COMPRESSION_LEVEL=6

# ================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ================================================================
#
# 1. JWT Secrets:
#    - NEVER use the defaults shown here
#    - Generate cryptographically secure random values
#    - Example: openssl rand -base64 48 | tr -d '\n'
#    - Store in secure secret management (Vault, K8s Secrets, etc.)
#    - Rotate periodically
#
# 2. Database:
#    - Use strong, random password
#    - Enable SSL/TLS for DB connections
#    - Use connection pooling (HikariCP configured)
#    - Monitor connection pool metrics
#
# 3. Redis:
#    - Set strong password if not already protected by network
#    - Use SSL/TLS for production
#
# 4. Kafka:
#    - Configure authentication (SASL/SCRAM)
#    - Use SSL/TLS for encryption
#    - Set proper ACLs for topics
#
# 5. General:
#    - Use SPRING_PROFILES_ACTIVE=prod for production
#    - Ensure all "must-be-set" variables are configured
#    - Enable HTTPS on the reverse proxy
#    - Monitor logs and metrics
#    - Set appropriate log levels (WARN for security-sensitive apps)
#    - Use distributed tracing in production
#
# ================================================================
